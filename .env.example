# Groq LLM API (zorunlu)
GROQ_API_KEY=gsk_...

# Firecrawl web scraping API (pipeline için zorunlu)
FIRECRAWL_API_KEY=fc-...

# Qdrant vector database (öncelik: Cloud URL > Local disk > Host:port)
# Seçenek 1 — Cloud (önerilen, takım çalışması için) ✅
# QDRANT_URL=https://xxxx.qdrant.io
# QDRANT_API_KEY=your-api-key
# Seçenek 2 — Local disk (Docker gerekmez, tek geliştirici için)
QDRANT_PATH=./qdrant_local
# Seçenek 3 — Docker/uzak sunucu (QDRANT_PATH boşsa kullanılır)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# CORS — virgülle ayrılmış origin listesi
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL (belek_chatbot şeması)
# Tüm değerler girilirse bağlantı kurulur; herhangi biri boşsa kayıt devre dışı kalır
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
