# =======================================================
# BÖLÜM 1: ORTAM VE İLİŞKİSEL VERİTABANI (TEST DB)
# =======================================================
# Uygulamanın çalıştığı ortam (development, test, production)
APP_ENV=test

# Veritabanı bağlantı URI'si (Örn: postgresql://kullanici:sifre@localhost:5432/belek_ai_test)
TEST_DATABASE_URL="veritabani_baglanti_urlnizi_buraya_yazin"

# Ayrıntılı veritabanı bilgileri (TEST_DATABASE_URL kullanmıyorsanız geçerlidir)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=veritabani_adiniz
DB_USER=veritabani_kullanici_adiniz
DB_PASSWORD=veritabani_sifreniz_buraya

# =======================================================
# BÖLÜM 2: YAPAY ZEKA VE QDRANT CLOUD
# =======================================================
# Groq platformundan alacağınız API anahtarı (gsk_ ile başlar)
GROQ_API_KEY=groq_api_anahtarinizi_buraya_yazin

# Firecrawl API anahtarı (Kullanıyorsanız)
FIRECRAWL_API_KEY=firecrawl_api_anahtarinizi_buraya_yazin

# Qdrant Cloud bağlantı bilgileri
QDRANT_URL=https://qdrant_cloud_urlnizi_buraya_yazin
QDRANT_API_KEY=qdrant_api_anahtarinizi_buraya_yazin